{
  "name": "messageKit-workspace",
  "private": "true",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix",
    "build:core": "bun run --filter @anand.dev.ai/messagekit-core build",
    "build:cli": "bun run --filter @anand.dev.ai/messagekit build",
    "build:local-mcp": "bun run --filter @anand.dev.ai/messagekit-mcp build",
    "dev:cli": "bun run packages/cli/src/index.ts",
    "dev:local-mcp": "bun run packages/local-mcp/src/index.ts",
    "dev:remote-mcp": "bun run apps/remote-mcp/src/index.ts",
    "release:pack:core": "bun run --filter @anand.dev.ai/messagekit-core pack:dry",
    "release:pack:cli": "bun run --filter @anand.dev.ai/messagekit pack:dry",
    "release:pack:local-mcp": "bun run --filter @anand.dev.ai/messagekit-mcp pack:dry",



    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "tsdown": "^0.22.8",
    "typescript": "^7.0.2"
  }
}
